{
  "name": "@placement/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "dev:worker": "nest start --watch --entryFile worker",
    "start": "node dist/src/main.js",
    "start:worker": "node dist/src/worker.js",
    "start:prod": "node dist/src/main.js",
    "lint": "tsc --noEmit",
    "db:migrate": "ts-node scripts/migrate.ts",
    "db:reset": "ts-node scripts/reset-db.ts",
    "db:seed": "ts-node scripts/seed.ts",
    "test:api": "ts-node scripts/test-apis.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "@placement/shared": "workspace:*",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.34.8",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "^0.38.3",
    "ioredis": "^5.4.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
